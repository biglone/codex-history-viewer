{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Codex History Viewer",
  "version": "0.1.0",
  "identifier": "com.biglone.codex-history-viewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Codex History Viewer",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
