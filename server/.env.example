# Codex Sync Server 环境变量

# 服务端口
PORT=3456

# PostgreSQL 连接
DATABASE_URL=postgresql://codex:codex123@localhost:5432/codex_sync

# API 鉴权 Token（客户端上传时需要携带此 Token）
# 建议修改为一个足够随机的字符串，例如：
# openssl rand -hex 32
API_TOKEN=your-secret-token-change-me

# 文件存储目录（JSONL 消息文件存放位置）
STORAGE_DIR=./storage

# 可选：服务公开域名（用于生成文件访问 URL）
# PUBLIC_URL=https://your-domain.com
